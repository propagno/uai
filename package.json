{
  "name": "uai-cc",
  "version": "0.2.3",
  "description": "UAI – Unidade de Análise Inteligente: framework de reverse engineering para sistemas legados COBOL, JCL, VB6, DB2",
  "homepage": "https://github.com/propagno/uai#readme",
  "bugs": {
    "url": "https://github.com/propagno/uai/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/propagno/uai.git"
  },
  "main": "lib/sdk/index.cjs",
  "bin": {
    "uai-cc": "bin/uai-cc.js"
  },
  "files": [
    "README.md",
    "bin/uai-cc.js",
    "lib",
    "src",
    ".cursor/commands",
    ".claude/skills",
    ".agents/skills",
    ".github/agents",
    ".github/prompts",
    ".github/workflows",
    "assets",
    "commands",
    "workflows",
    "templates",
    "scripts"
  ],
  "scripts": {
    "test": "node --test tests/*.test.cjs",
    "test:coverage": "c8 --check-coverage --lines 82 --functions 85 npm test",
    "sync:commands": "node scripts/sync-commands.cjs",
    "prepublishOnly": "node bin/uai-cc.js sync-commands --root . && npm test"
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^12.0.0",
    "inquirer": "^8.2.7",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "c8": "^9.1.0"
  },
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "cobol",
    "jcl",
    "vb6",
    "db2",
    "legacy",
    "reverse-engineering",
    "mainframe",
    "analysis"
  ],
  "license": "MIT"
}
